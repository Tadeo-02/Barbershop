# ============================================================================
# DOCKER & DEPLOYMENT CONFIGURATION
# ============================================================================

# Environment (development, staging, production)
NODE_ENV=production

# Port Configuration
PORT=3001
BACKEND_PORT=3001
FRONTEND_PORT=3000

# Frontend URL (for CORS configuration)
# Development: http://localhost:5173 (Vite dev server)
# Docker Dev: http://localhost:3000
# Production: https://your-frontend-domain.com
FRONTEND_URL=http://localhost:3000

# ============================================================================
# REMOTE DATABASE CONFIGURATION (MySQL)
# ============================================================================

# Your remote MySQL database URL
# Format: mysql://USERNAME:PASSWORD@HOST:PORT/DATABASE
# Example: mysql://barbershop_user:mypassword@db.example.com:3306/barbershop
# Or for local: mysql://barbershop_user:mypassword@localhost:3306/barbershop
DATABASE_URL="mysql://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_DB_HOST:3306/YOUR_DB_NAME"

# Alternatively, use individual variables (DATABASE_URL takes precedence)
# DB_HOST=db.example.com
# DB_PORT=3306
# DB_USER=barbershop_user
# DB_PASSWORD=your_secure_password
# DB_NAME=barbershop

# ============================================================================
# SECURITY SETTINGS
# ============================================================================

# Rate Limiting (Optional - defaults are set in code)
# RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
# RATE_LIMIT_MAX=100           # max requests per window
# AUTH_RATE_LIMIT_MAX=5        # max auth attempts per window

# ============================================================================
# ARCA (ex-AFIP) - FACTURACIÓN ELECTRÓNICA
# ============================================================================

# Obtener access_token en https://app.afipsdk.com
AFIP_ACCESS_TOKEN=tu-access-token-aqui

# CUIT del negocio (sin guiones). Default: 20409378472 (testing)
AFIP_CUIT=20409378472

# "testing" o "production"
AFIP_ENVIRONMENT=testing

# Punto de venta habilitado para facturación electrónica
AFIP_PUNTO_VENTA=1

# Solo producción: rutas al certificado y clave (mount as volumes in Docker)
# AFIP_CERT_PATH=./certs/certificado.crt
# AFIP_KEY_PATH=./certs/clave.key

# ============================================================================
# EMAIL CONFIGURATION (SMTP) - OPTIONAL
# ============================================================================

# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-email-password
